        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "geoip-lite": "^1.4.10",
        "helmet": "^8.1.0",
        "ioredis": "^5.9.2",
        "jsonwebtoken": "^9.0.3",
        "prettier": "^3.8.1",
        "prisma": "^6.19.2",
        "prom-client": "^15.1.3",
        "ua-parser-js": "^2.0.8",
        "uuid": "^9.0.1",
